{% extends 'base.html.twig' %}
{% block title %}WorkTogether Data Solutions{% endblock %}

{% block body %}
<style>
    /* ── Hero ── */
    .hero {
        position: relative;
        padding: 8rem 0 6rem;
        text-align: center;
        overflow: hidden;
    }

    /* Animated grid lines behind hero */
    .hero__grid {
        position: absolute; inset: 0; pointer-events: none; overflow: hidden;
    }
    .hero__grid svg { width: 100%; height: 100%; opacity: .12; }

    /* Floating badge */
    .hero__badge {
        display: inline-flex; align-items: center; gap: .5rem;
        background: rgba(139,92,246,.12);
        border: 1px solid rgba(139,92,246,.3);
        backdrop-filter: blur(10px);
        border-radius: 100px;
        padding: .4rem 1rem .4rem .5rem;
        font-family: var(--mono);
        font-size: .72rem;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: #c4b5fd;
        margin-bottom: 2rem;
        animation: fadeUp .6s ease both;
    }
    .hero__badge-dot {
        width: 6px; height: 6px; border-radius: 50%; background: var(--violet);
        box-shadow: 0 0 8px var(--violet); animation: badgeDot 2s ease-in-out infinite;
    }
    @keyframes badgeDot { 0%,100%{opacity:1;box-shadow:0 0 8px var(--violet)} 50%{opacity:.4;box-shadow:0 0 16px var(--violet)} }

    .hero__title {
        font-size: clamp(3rem, 8vw, 6.5rem);
        font-weight: 900;
        letter-spacing: -.05em;
        line-height: 1;
        margin-bottom: 1.6rem;
        animation: fadeUp .7s .1s ease both;
    }
    .hero__title .line-2 { display: block; }

    .hero__sub {
        font-size: clamp(.95rem, 2vw, 1.15rem);
        color: var(--muted);
        max-width: 520px;
        margin: 0 auto 2.8rem;
        line-height: 1.72;
        font-weight: 300;
        animation: fadeUp .7s .2s ease both;
    }

    .hero__actions {
        display: flex; align-items: center; justify-content: center;
        gap: 1rem; flex-wrap: wrap;
        animation: fadeUp .7s .3s ease both;
    }

    /* Scroll hint */
    .hero__scroll {
        margin-top: 4rem;
        display: flex; flex-direction: column; align-items: center; gap: .5rem;
        color: var(--muted2);
        font-family: var(--mono); font-size: .65rem; letter-spacing: .12em; text-transform: uppercase;
        animation: fadeUp .7s .5s ease both;
    }
    .hero__scroll-line {
        width: 1px; height: 48px;
        background: linear-gradient(to bottom, var(--violet), transparent);
        animation: scrollLine 2s ease-in-out infinite;
    }
    @keyframes scrollLine { 0%{opacity:0;transform:scaleY(0);transform-origin:top} 50%{opacity:1;transform:scaleY(1)} 100%{opacity:0;transform:scaleY(1);transform-origin:bottom} }

    @keyframes fadeUp {
        from { opacity:0; transform:translateY(28px); }
        to   { opacity:1; transform:translateY(0); }
    }

    /* ── Stats band ── */
    .stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        overflow: hidden;
        margin: 0 0 5rem;
        backdrop-filter: var(--blur);
    }
    .stat {
        background: rgba(7,6,15,.6);
        backdrop-filter: var(--blur);
        padding: 2.2rem 1.5rem;
        text-align: center;
        transition: background .25s;
    }
    .stat:hover { background: rgba(139,92,246,.06); }
    .stat__num {
        font-size: 2.8rem; font-weight: 900; letter-spacing: -.05em; line-height: 1;
        background: linear-gradient(135deg, #c4b5fd, var(--cyan));
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        margin-bottom: .4rem;
    }
    .stat__label {
        font-family: var(--mono); font-size: .68rem; text-transform: uppercase;
        letter-spacing: .12em; color: var(--muted);
    }

    /* ── Section title ── */
    .section-head {
        text-align: center; margin-bottom: 3rem;
    }
    .section-head__title {
        font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 800;
        letter-spacing: -.04em; margin-bottom: .6rem;
    }
    .section-head__sub { color: var(--muted); font-size: .95rem; font-weight: 300; line-height: 1.65; }

    /* ── Feature grid ── */
    .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.25rem;
        margin-bottom: 5rem;
    }
    .feature {
        background: var(--glass);
        backdrop-filter: var(--blur);
        -webkit-backdrop-filter: var(--blur);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        padding: 2rem;
        transition: border-color .25s, transform .25s, box-shadow .25s;
        position: relative; overflow: hidden;
    }
    .feature::before {
        content: '';
        position: absolute; inset: 0; border-radius: var(--r-lg);
        background: linear-gradient(135deg, rgba(139,92,246,.06) 0%, transparent 60%);
        opacity: 0; transition: opacity .3s;
    }
    .feature:hover { border-color: rgba(139,92,246,.4); transform: translateY(-5px); box-shadow: 0 20px 60px rgba(0,0,0,.5), 0 0 0 1px rgba(139,92,246,.15) inset; }
    .feature:hover::before { opacity: 1; }

    /* Top accent line on hover */
    .feature::after {
        content: '';
        position: absolute; top: 0; left: 0; right: 0; height: 2px;
        background: linear-gradient(90deg, var(--violet), var(--cyan));
        opacity: 0; transition: opacity .3s;
        border-radius: var(--r-lg) var(--r-lg) 0 0;
    }
    .feature:hover::after { opacity: 1; }

    .feature__icon {
        width: 48px; height: 48px; border-radius: 12px;
        background: linear-gradient(135deg, rgba(139,92,246,.18), rgba(6,214,247,.12));
        border: 1px solid rgba(139,92,246,.25);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; margin-bottom: 1.3rem;
        box-shadow: 0 4px 16px rgba(139,92,246,.2);
    }
    .feature__title { font-size: 1rem; font-weight: 700; margin-bottom: .55rem; letter-spacing: -.02em; }
    .feature__desc  { color: var(--muted); font-size: .875rem; line-height: 1.65; font-weight: 300; }

    /* ── CTA banner ── */
    .cta-banner {
        position: relative; overflow: hidden;
        background: var(--glass);
        backdrop-filter: var(--blur);
        -webkit-backdrop-filter: var(--blur);
        border: 1px solid rgba(139,92,246,.25);
        border-radius: 24px;
        padding: 4rem 3rem;
        text-align: center;
        margin-bottom: 5rem;
    }
    .cta-banner::before {
        content: '';
        position: absolute; top: -100px; left: 50%; transform: translateX(-50%);
        width: 500px; height: 280px;
        background: radial-gradient(ellipse, rgba(139,92,246,.18) 0%, transparent 70%);
        pointer-events: none;
    }
    .cta-banner__title {
        font-size: clamp(1.6rem, 3vw, 2.6rem);
        font-weight: 900; letter-spacing: -.04em; margin-bottom: .8rem;
    }
    .cta-banner__sub {
        color: var(--muted); font-size: 1rem; margin-bottom: 2.2rem; font-weight: 300;
    }
    .cta-banner__actions { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
</style>

<!-- HERO -->
<section class="hero">
    <div class="hero__grid" aria-hidden="true">
        <svg viewBox="0 0 1200 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
                    <path d="M 60 0 L 0 0 0 60" fill="none" stroke="rgba(139,92,246,1)" stroke-width=".6"/>
                </pattern>
                <radialGradient id="fade" cx="50%" cy="50%" r="55%">
                    <stop offset="0%" stop-color="white" stop-opacity="1"/>
                    <stop offset="100%" stop-color="white" stop-opacity="0"/>
                </radialGradient>
                <mask id="m"><rect width="1200" height="600" fill="url(#fade)"/></mask>
            </defs>
            <rect width="1200" height="600" fill="url(#grid)" mask="url(#m)"/>
        </svg>
    </div>

    <div class="wt-container" style="position:relative;">
        <div class="hero__badge">
            <span class="hero__badge-dot"></span>
            Infrastructure · Datacenter · Colocation
        </div>

        <h1 class="hero__title">
            <span class="grad-text">Votre infrastructure,</span>
            <span class="line-2">sans compromis.</span>
        </h1>

        <p class="hero__sub">
            Hébergez vos équipements dans nos baies haute densité — connectivité ultrarapide, redondance totale, sécurité physique de niveau enterprise.
        </p>

        <div class="hero__actions">
            <a href="{{ path('app_offers') }}" class="btn btn-primary btn-lg">
                Voir les offres
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            {% if not app.user %}
            <a href="{{ path('app_registration') }}" class="btn btn-glow btn-lg">Créer un compte</a>
            {% else %}
            <a href="{{ path('app_dashboard') }}" class="btn btn-ghost btn-lg">Mon espace</a>
            {% endif %}
        </div>

        <div class="hero__scroll">
            <div class="hero__scroll-line"></div>
            <span>Découvrir</span>
        </div>
    </div>
</section>

<div class="wt-container">

    <!-- STATS -->
    <div class="stats">
        <div class="stat">
            <div class="stat__num">30</div>
            <div class="stat__label">Baies actives</div>
        </div>
        <div class="stat">
            <div class="stat__num">1&thinsp;260</div>
            <div class="stat__label">Unités disponibles</div>
        </div>
        <div class="stat">
            <div class="stat__num">99,9%</div>
            <div class="stat__label">Uptime garanti</div>
        </div>
    </div>

    <!-- FEATURES -->
    <div class="section-head">
        <span class="wt-label">Pourquoi WorkTogether</span>
        <h2 class="section-head__title grad-text">Une plateforme pensée<br>pour les pros</h2>
        <p class="section-head__sub">De la connectivité à la sécurité, chaque détail est maîtrisé.</p>
    </div>

    <div class="features">
        <div class="feature">
            <div class="feature__icon">⚡</div>
            <div class="feature__title">Connectivité ultrarapide</div>
            <p class="feature__desc">Accès réseau multi-opérateurs redondant avec des débits jusqu'à 100 Gbps pour vos applications critiques.</p>
        </div>
        <div class="feature">
            <div class="feature__icon">🔒</div>
            <div class="feature__title">Sécurité physique</div>
            <p class="feature__desc">Contrôle d'accès biométrique, vidéosurveillance 24/7 et agents de sécurité dédiés pour protéger vos actifs.</p>
        </div>
        <div class="feature">
            <div class="feature__icon">🔋</div>
            <div class="feature__title">Redondance électrique</div>
            <p class="feature__desc">Alimentation N+1 avec onduleurs et groupes électrogènes assurant 100% de continuité opérationnelle.</p>
        </div>
        <div class="feature">
            <div class="feature__icon">🌡</div>
            <div class="feature__title">Refroidissement précis</div>
            <p class="feature__desc">Climatisation de précision maintenant une température entre 18 et 27°C dans toutes les allées de baies.</p>
        </div>
        <div class="feature">
            <div class="feature__icon">📊</div>
            <div class="feature__title">Monitoring temps réel</div>
            <p class="feature__desc">Tableau de bord dédié : consommation, température, débit réseau — tout visible depuis votre espace client.</p>
        </div>
        <div class="feature">
            <div class="feature__icon">🛠</div>
            <div class="feature__title">Support expert</div>
            <p class="feature__desc">Équipe technique disponible pour toute intervention avec des SLA définis contractuellement et respectés.</p>
        </div>
    </div>

    <!-- CTA BANNER -->
    <div class="cta-banner">
        <h2 class="cta-banner__title">Prêt à démarrer ?</h2>
        <p class="cta-banner__sub">Rejoignez les entreprises qui nous font confiance pour leur infrastructure critique.</p>
        <div class="cta-banner__actions">
            <a href="{{ path('app_offers') }}" class="btn btn-primary btn-lg">Voir les offres</a>
            {% if not app.user %}
            <a href="{{ path('app_registration') }}" class="btn btn-ghost btn-lg">S'inscrire gratuitement</a>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}
