{% extends 'base.html.twig' %}

{% block title %}Avis clients — WorkTogether{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ── Hero ── */
        .notices-hero {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            color: #fff;
            padding: 60px 0 40px;
            text-align: center;
        }
        .notices-hero h1 {
            font-size: 2.4rem;
            font-weight: 700;
            letter-spacing: -0.5px;
        }
        .notices-hero p {
            color: #a0b4cc;
            font-size: 1.05rem;
        }

        /* ── Moyenne globale ── */
        .average-badge {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 50px;
            padding: 10px 24px;
            margin-top: 16px;
        }
        .average-badge .score {
            font-size: 1.8rem;
            font-weight: 800;
            color: #ffc107;
        }
        .average-badge .label {
            font-size: 0.85rem;
            color: #a0b4cc;
            line-height: 1.3;
        }

        /* ── Carte avis ── */
        .notice-card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.07);
            transition: transform 0.2s, box-shadow 0.2s;
            height: 100%;
        }
        .notice-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        }
        .notice-card .card-body {
            padding: 24px;
        }
        .stars {
            color: #ffc107;
            font-size: 1.1rem;
            letter-spacing: 2px;
        }
        .stars .empty {
            color: #dee2e6;
        }
        .notice-comment {
            color: #444;
            font-style: italic;
            line-height: 1.6;
            margin: 12px 0;
            font-size: 0.95rem;
        }
        .notice-author {
            font-weight: 600;
            color: #1a1a2e;
            font-size: 0.9rem;
        }
        .notice-author span {
            font-weight: 400;
            color: #6c757d;
            font-size: 0.8rem;
        }

        /* ── Formulaire ── */
        .notice-form-section {
            background: #f8f9fa;
            border-top: 3px solid #0f3460;
            padding: 48px 0;
        }
        .notice-form-card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.08);
            overflow: hidden;
        }
        .notice-form-card .card-header {
            background: linear-gradient(135deg, #1a1a2e, #0f3460);
            color: #fff;
            padding: 20px 28px;
            border: none;
        }
        .notice-form-card .card-header h4 {
            margin: 0;
            font-weight: 600;
            font-size: 1.15rem;
        }
        .notice-form-card .card-body {
            padding: 28px;
        }
        .btn-submit-notice {
            background: linear-gradient(135deg, #1a1a2e, #0f3460);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 28px;
            font-weight: 600;
            transition: opacity 0.2s;
        }
        .btn-submit-notice:hover {
            opacity: 0.88;
            color: #fff;
        }

        /* ── Badge note ── */
        .note-badge {
            display: inline-block;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #0f3460;
            color: #fff;
            font-weight: 700;
            font-size: 0.9rem;
            line-height: 36px;
            text-align: center;
            margin-right: 8px;
        }

        /* ── Empty state ── */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #6c757d;
        }
        .empty-state .icon {
            font-size: 3rem;
            margin-bottom: 16px;
        }
    </style>
{% endblock %}

{% block body %}

{# ── Hero ── #}
<div class="notices-hero">
    <div class="container">
        <h1>⭐ Avis de nos clients</h1>
        <p>Découvrez ce que nos clients pensent de nos services</p>

        {% if notices|length > 0 %}
            {% set total = 0 %}
            {% for n in notices %}{% set total = total + n.note %}{% endfor %}
            {% set average = (total / notices|length)|round(1) %}
            <div class="average-badge">
                <span class="score">{{ average }}</span>
                <span class="label">
                    Note moyenne<br>
                    sur {{ notices|length }} avis
                </span>
            </div>
        {% endif %}
    </div>
</div>

<div class="container py-5">

    {# ── Flash messages ── #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            ✅ {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('warning') %}
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            ⚠️ {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            ❌ {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {# ── Grille des avis ── #}
    {% if notices is empty %}
        <div class="empty-state">
            <div class="icon">💬</div>
            <h4>Aucun avis pour le moment</h4>
            <p>Soyez le premier à partager votre expérience !</p>
        </div>
    {% else %}
        <div class="row g-4 mb-5">
            {% for notice in notices %}
            <div class="col-md-6 col-lg-4">
                <div class="notice-card card">
                    <div class="card-body">
                        {# Étoiles #}
                        <div class="stars mb-2">
                            {% for i in 1..5 %}
                                {% if i <= notice.note %}★{% else %}<span class="empty">★</span>{% endif %}
                            {% endfor %}
                            <span class="note-badge ms-1">{{ notice.note }}</span>
                        </div>

                        {# Commentaire #}
                        <p class="notice-comment">"{{ notice.comment }}"</p>

                        {# Auteur #}
                        <div class="notice-author">
                            {{ notice.customer.firstName }} {{ notice.customer.name|slice(0,1) }}.
                            <span>
                                {% if notice.customer.isParticular() %}
                                    Client particulier
                                {% else %}
                                    {{ notice.customer.companyName }}
                                {% endif %}
                            </span>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}

</div>


{% endblock %}
