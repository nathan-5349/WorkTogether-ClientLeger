{% extends 'base.html.twig' %}
{% block title %}Commander · {{ offer.name }}{% endblock %}

{% block body %}
<div class="wt-container">
    <div style="max-width:520px; margin:0 auto; padding:3.5rem 0;">
        <span class="wt-label">Nouvelle commande</span>
        <h1 class="wt-h1" style="font-size:1.8rem; margin-bottom:.5rem;">{{ offer.name }}</h1>
        <p style="font-family:var(--mono); margin-bottom:2rem;">
            <span style="background:linear-gradient(135deg,#c4b5fd,var(--cyan)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; font-size:1.2rem; font-weight:700;">{{ offer.price }} €</span>
            <span style="color:var(--muted); font-size:.82rem;">/mois · {{ offer.nbUnit }} unité{{ offer.nbUnit > 1 ? 's' : '' }}</span>
        </p>

        <div style="background:var(--glass); backdrop-filter:var(--blur); -webkit-backdrop-filter:var(--blur); border:1px solid var(--border); border-radius:var(--r-lg); padding:2rem;">
            {{ form_start(form) }}
                {{ form_row(form.beginDate) }}
                {{ form_row(form.duration) }}
                <div style="background:rgba(6,214,247,.05); border:1px solid rgba(6,214,247,.15); border-radius:var(--r-sm); padding:.9rem 1.1rem; margin:1.25rem 0; font-family:var(--mono); font-size:.75rem; color:var(--muted);">
                    💡 Les unités seront automatiquement assignées parmi les emplacements disponibles.
                </div>
                <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:.8rem;">
                    Confirmer la commande
                </button>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
