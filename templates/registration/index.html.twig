{% extends 'base.html.twig' %}
{% block title %}Créer un compte{% endblock %}

{% block body %}
<style>
    .reg-wrap {
        min-height: calc(100vh - 68px);
        display: flex; align-items: center; justify-content: center; padding: 2rem;
    }
    .reg-choice { width: 100%; max-width: 540px; text-align: center; }
    .reg-choice__title {
        font-size: 2rem; font-weight: 900; letter-spacing: -.04em; margin-bottom: .5rem;
    }
    .reg-choice__sub { color: var(--muted); font-size: .9rem; margin-bottom: 2.5rem; font-weight: 300; }
    .reg-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
    .reg-card {
        background: var(--glass); backdrop-filter: var(--blur); -webkit-backdrop-filter: var(--blur);
        border: 1px solid var(--border); border-radius: var(--r-lg);
        padding: 2rem 1.5rem; text-decoration: none; color: var(--text);
        display: flex; flex-direction: column; align-items: center; gap: 1rem;
        transition: border-color .25s, transform .25s, box-shadow .25s;
    }
    .reg-card:hover {
        border-color: var(--border-h); transform: translateY(-4px);
        box-shadow: 0 16px 48px rgba(0,0,0,.4);
    }
    .reg-card__icon { font-size: 2rem; }
    .reg-card__label { font-weight: 700; font-size: 1rem; }
    .reg-card__desc  { font-size: .82rem; color: var(--muted); text-align: center; line-height: 1.55; font-weight: 300; }
    .reg-footer {
        text-align: center; margin-top: 1.5rem;
        font-family: var(--mono); font-size: .72rem; color: var(--muted);
    }
    .reg-footer a { color: var(--cyan); text-decoration: none; }
</style>
    <div class="reg-wrap">
        <div class="reg-choice">
            <span class="wt-label" style="justify-content:center; display:flex;">{{ 'registration.label'|trans }}</span>
            <h1 class="reg-choice__title">{{ 'registration.title'|trans }}</h1>
            <p class="reg-choice__sub">{{ 'registration.sub'|trans }}</p>
            <div class="reg-cards">
                <a href="{{ path('app_particular_registration') }}" class="reg-card">
                    <div class="reg-card__icon">👤</div>
                    <div class="reg-card__label">{{ 'registration.particular'|trans }}</div>
                    <p class="reg-card__desc">{{ 'registration.particularDesc'|trans }}</p>
                </a>
                <a href="{{ path('app_company_registration') }}" class="reg-card">
                    <div class="reg-card__icon">🏢</div>
                    <div class="reg-card__label">{{ 'registration.company'|trans }}</div>
                    <p class="reg-card__desc">{{ 'registration.companyDesc'|trans }}</p>
                </a>
            </div>
            <div class="reg-footer">
                {{ 'registration.alreadyAccount'|trans }} <a href="{{ path('app_login') }}">{{ 'registration.loginLink'|trans }}</a>
            </div>
        </div>
    </div>
{% endblock %}
