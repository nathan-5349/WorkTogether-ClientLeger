{% extends 'base.html.twig' %}

{% block title %}Créer un compte{% endblock %}

{% block body %}
<div class="container mt-5 text-center">
    <h1>Créer un compte</h1>
    <p>Quel type de compte souhaitez-vous créer ?</p>
    <div class="row justify-content-center mt-4">
        <div class="col-md-3">
            <a href="{{ path('app_particular_registration') }}" class="btn btn-primary btn-lg w-100">
                Particulier
            </a>
        </div>
        <div class="col-md-3">
            <a href="{{ path('app_company_registration') }}" class="btn btn-secondary btn-lg w-100">
                Entreprise
            </a>
        </div>
    </div>
</div>
{% endblock %}
