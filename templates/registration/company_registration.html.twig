{% extends 'base.html.twig' %}
{% block title %}Inscription Entreprise{% endblock %}

{% block body %}
    <div class="wt-container">
        <div style="max-width:580px; margin:0 auto; padding:3.5rem 0;">
            <span class="wt-label">{{ 'registration.labelCompany'|trans }}</span>
            <h1 class="wt-h1" style="font-size:1.8rem; margin-bottom:2rem;">{{ 'registration.titleCompany'|trans }}</h1>

            <div style="background:var(--glass); backdrop-filter:var(--blur); -webkit-backdrop-filter:var(--blur); border:1px solid var(--border); border-radius:var(--r-lg); padding:2rem;">
                {{ form_start(form) }}
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:0 1.25rem;">
                    {{ form_row(form.firstName) }}
                    {{ form_row(form.name) }}
                </div>
                {{ form_row(form.email) }}
                {{ form_row(form.password) }}
                {{ form_row(form.phone) }}
                {{ form_row(form.adress) }}
                {{ form_row(form.invoiceAdress) }}
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:0 1.25rem;">
                    {{ form_row(form.siret) }}
                    {{ form_row(form.companyName) }}
                </div>
                <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:.8rem; margin-top:1.25rem;">
                    {{ 'registration.submit'|trans }}
                </button>
                {{ form_end(form) }}
            </div>

            <p style="text-align:center; margin-top:1.25rem; font-family:var(--mono); font-size:.72rem; color:var(--muted);">
                {{ 'registration.alreadyAccount'|trans }} <a href="{{ path('app_login') }}" style="color:var(--cyan);">{{ 'registration.loginLink'|trans }}</a>
            </p>
        </div>
    </div>
{% endblock %}
