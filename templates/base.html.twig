<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}WorkTogether Data Solutions{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800;900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">

    {% block stylesheets %}
    <style>
        /* ── Variables ── */
        :root {
            --bg:        #07060f;
            --glass:     rgba(255,255,255,0.055);
            --glass-b:   rgba(255,255,255,0.12);
            --glass-s:   rgba(255,255,255,0.04);
            --border:    rgba(255,255,255,0.10);
            --border-h:  rgba(255,255,255,0.22);

            --violet:    #8b5cf6;
            --cyan:      #06d6f7;
            --rose:      #f43f8e;
            --lime:      #a3e635;

            --text:      #f0eeff;
            --muted:     rgba(240,238,255,0.45);
            --muted2:    rgba(240,238,255,0.25);

            --display:   'Outfit', sans-serif;
            --mono:      'DM Mono', monospace;

            --blur:      blur(20px) saturate(160%);
            --blur-sm:   blur(10px) saturate(140%);

            --r-lg:      18px;
            --r-md:      12px;
            --r-sm:      8px;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }

        body {
            font-family: var(--display);
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* ── Ambient orbs (fixed, behind everything) ── */
        .wt-orbs {
            position: fixed; inset: 0;
            pointer-events: none; z-index: 0; overflow: hidden;
        }
        .wt-orb {
            position: absolute; border-radius: 50%;
            filter: blur(90px); opacity: .42;
            animation: orbFloat 16s ease-in-out infinite;
        }
        .wt-orb--1 {
            width: 620px; height: 620px;
            background: radial-gradient(circle, #8b5cf6 0%, transparent 70%);
            top: -200px; left: -180px; animation-duration: 18s;
        }
        .wt-orb--2 {
            width: 520px; height: 520px;
            background: radial-gradient(circle, #06d6f7 0%, transparent 70%);
            top: 15%; right: -180px; animation-duration: 22s; animation-delay: -6s;
        }
        .wt-orb--3 {
            width: 440px; height: 440px;
            background: radial-gradient(circle, #f43f8e 0%, transparent 70%);
            bottom: 8%; left: 22%; animation-duration: 20s; animation-delay: -11s; opacity: .3;
        }
        .wt-orb--4 {
            width: 300px; height: 300px;
            background: radial-gradient(circle, #a3e635 0%, transparent 70%);
            bottom: -80px; right: 8%; animation-duration: 24s; animation-delay: -4s; opacity: .2;
        }
        @keyframes orbFloat {
            0%,100% { transform: translate(0,0) scale(1); }
            33%      { transform: translate(28px,-44px) scale(1.07); }
            66%      { transform: translate(-22px,28px) scale(.94); }
        }

        /* Grain overlay */
        body::after {
            content: '';
            position: fixed; inset: 0; z-index: 1; pointer-events: none;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
            opacity: .55;
        }

        /* Everything above orbs */
        .wt-nav, .wt-page, section, footer { position: relative; z-index: 2; }

        /* ── Navbar ── */
        .wt-nav {
            position: sticky; top: 0; z-index: 100;
            height: 68px;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 2.5rem;
            background: rgba(7,6,15,0.5);
            backdrop-filter: var(--blur);
            -webkit-backdrop-filter: var(--blur);
            border-bottom: 1px solid var(--border);
        }

        .wt-nav__brand {
            font-family: var(--display);
            font-weight: 800; font-size: 1.15rem; letter-spacing: -.03em;
            color: var(--text); text-decoration: none;
            display: flex; align-items: center; gap: .55rem;
        }
        .wt-nav__brand-icon {
            width: 32px; height: 32px; border-radius: 9px;
            background: linear-gradient(135deg, var(--violet), var(--cyan));
            display: flex; align-items: center; justify-content: center;
            font-size: .9rem;
            box-shadow: 0 0 18px rgba(139,92,246,.55);
        }
        .wt-nav__links { display: flex; align-items: center; gap: .15rem; }
        .wt-nav__link {
            font-size: .84rem; font-weight: 500; color: var(--muted);
            text-decoration: none; padding: .45rem .95rem; border-radius: var(--r-sm);
            transition: color .2s, background .2s; letter-spacing: -.01em;
        }
        .wt-nav__link:hover { color: var(--text); background: var(--glass); }
        .wt-nav__link--pill {
            background: linear-gradient(135deg, rgba(139,92,246,.2), rgba(6,214,247,.15));
            border: 1px solid rgba(139,92,246,.3);
            color: var(--text); font-weight: 600;
        }
        .wt-nav__link--pill:hover {
            background: linear-gradient(135deg, rgba(139,92,246,.38), rgba(6,214,247,.28));
            border-color: rgba(139,92,246,.6);
            box-shadow: 0 0 18px rgba(139,92,246,.28);
        }

        /* ── Glass card ── */
        .glass {
            background: var(--glass);
            backdrop-filter: var(--blur);
            -webkit-backdrop-filter: var(--blur);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            transition: border-color .25s;
        }
        .glass:hover { border-color: var(--border-h); }
        .glass--s {
            background: var(--glass-s);
            backdrop-filter: var(--blur-sm);
            -webkit-backdrop-filter: var(--blur-sm);
            border: 1px solid var(--border);
            border-radius: var(--r-md);
        }

        /* ── Buttons ── */
        .btn {
            display: inline-flex; align-items: center; justify-content: center; gap: .4rem;
            font-family: var(--display); font-weight: 600; font-size: .875rem;
            padding: .65rem 1.5rem; border-radius: var(--r-sm);
            border: none; cursor: pointer; text-decoration: none;
            transition: all .22s; letter-spacing: -.01em;
        }
        .btn-primary {
            background: linear-gradient(135deg, var(--violet), #5b21b6);
            color: #fff; box-shadow: 0 4px 24px rgba(139,92,246,.38);
        }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(139,92,246,.58); filter: brightness(1.12); }
        .btn-glow {
            background: linear-gradient(135deg, rgba(6,214,247,.12), rgba(139,92,246,.12));
            border: 1px solid rgba(6,214,247,.32); color: var(--cyan);
        }
        .btn-glow:hover {
            background: linear-gradient(135deg, rgba(6,214,247,.26), rgba(139,92,246,.2));
            border-color: var(--cyan); box-shadow: 0 0 22px rgba(6,214,247,.3);
            transform: translateY(-2px);
        }
        .btn-ghost {
            background: var(--glass); border: 1px solid var(--border); color: var(--text);
            backdrop-filter: var(--blur-sm);
        }
        .btn-ghost:hover { border-color: var(--border-h); background: var(--glass-b); transform: translateY(-2px); }
        .btn-success {
            background: linear-gradient(135deg, #10b981, #059669); color: #fff;
            box-shadow: 0 4px 20px rgba(16,185,129,.3);
        }
        .btn-success:hover { transform: translateY(-2px); filter: brightness(1.1); }
        .btn-secondary { background: var(--glass); border: 1px solid var(--border); color: var(--muted); }
        .btn-secondary:hover { color: var(--text); border-color: var(--border-h); }
        .btn-lg { padding: .9rem 2.3rem; font-size: .95rem; border-radius: var(--r-md); }
        .btn-sm { padding: .38rem .85rem; font-size: .77rem; }

        /* ── Typography ── */
        .wt-label {
            font-family: var(--mono); font-size: .68rem; letter-spacing: .15em;
            text-transform: uppercase; color: var(--cyan); display: block; margin-bottom: .55rem;
        }
        .wt-h1 { font-family: var(--display); font-weight: 900; letter-spacing: -.04em; line-height: 1.04; }
        .grad-text {
            background: linear-gradient(135deg, #c4b5fd 0%, var(--cyan) 50%, var(--rose) 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }

        /* ── Forms ── */
        form label {
            display: block; font-family: var(--mono); font-size: .68rem;
            letter-spacing: .1em; text-transform: uppercase; color: var(--muted); margin-bottom: .4rem;
        }
        form input[type="text"], form input[type="email"], form input[type="password"],
        form input[type="date"], form input[type="number"], form select, form textarea {
            width: 100%; background: rgba(255,255,255,.05); border: 1px solid var(--border);
            border-radius: var(--r-sm); color: var(--text); padding: .72rem 1rem;
            font-family: var(--mono); font-size: .83rem; outline: none;
            transition: border-color .2s, box-shadow .2s, background .2s;
        }
        form input:focus, form select:focus, form textarea:focus {
            border-color: var(--violet); background: rgba(139,92,246,.07);
            box-shadow: 0 0 0 3px rgba(139,92,246,.18);
        }
        .form-group, div[class*="mb-"] { margin-bottom: 1.2rem; }
        .form-check { display: flex; align-items: center; gap: .5rem; margin-bottom: .5rem; }
        .form-check-input { width: auto; accent-color: var(--violet); }
        .form-check-label { font-size: .83rem; color: var(--text); font-family: var(--mono); text-transform: none; letter-spacing: 0; }

        .invalid-feedback, ul.form-errors { color: var(--rose); font-size: .75rem; font-family: var(--mono); margin-top: .3rem; }
        .alert-danger {
            background: rgba(244,63,142,.08); border: 1px solid rgba(244,63,142,.25);
            color: #fda4c6; padding: .9rem 1.2rem; border-radius: var(--r-sm);
            font-family: var(--mono); font-size: .8rem; margin-bottom: 1.5rem;
        }

        /* ── Badges ── */
        .wt-badge {
            display: inline-flex; align-items: center; gap: .35rem;
            font-family: var(--mono); font-size: .67rem; letter-spacing: .06em;
            text-transform: uppercase; padding: .28rem .65rem; border-radius: 4px; font-weight: 500;
        }
        .wt-badge::before { content: ''; width: 5px; height: 5px; border-radius: 50%; }
        .wt-badge--ok   { background: rgba(163,230,53,.1); color: var(--lime); }
        .wt-badge--ok::before { background: var(--lime); }
        .wt-badge--warn { background: rgba(245,158,11,.1); color: #fbbf24; }
        .wt-badge--warn::before { background: #fbbf24; animation: bPulse 2s infinite; }
        .wt-badge--off  { background: rgba(255,255,255,.05); color: var(--muted); }
        .wt-badge--off::before { background: var(--muted); }
        @keyframes bPulse { 0%,100%{opacity:1} 50%{opacity:.25} }

        /* ── Flash ── */
        .wt-flash { padding: .85rem 1.2rem; border-radius: var(--r-sm); font-family: var(--mono); font-size: .8rem; margin-bottom: 1.5rem; }
        .wt-flash--success { background: rgba(163,230,53,.08); border: 1px solid rgba(163,230,53,.25); color: #bef264; }
        .wt-flash--error   { background: rgba(244,63,142,.08); border: 1px solid rgba(244,63,142,.25); color: #fda4c6; }

        /* ── Layout ── */
        .wt-container { max-width: 1140px; margin: 0 auto; padding: 0 2rem; }
        .wt-page      { padding: 3.5rem 0 6rem; }
        .wt-divider   { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }

        /* ── Scrollbar ── */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: rgba(139,92,246,.4); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--violet); }
    </style>
    {% endblock %}
</head>
<body>

    <div class="wt-orbs" aria-hidden="true">
        <div class="wt-orb wt-orb--1"></div>
        <div class="wt-orb wt-orb--2"></div>
        <div class="wt-orb wt-orb--3"></div>
        <div class="wt-orb wt-orb--4"></div>
    </div>

    <nav class="wt-nav">
        <a class="wt-nav__brand" href="{{ path('app_home') }}">
            <div class="wt-nav__brand-icon">⬡</div>
            WorkTogether
        </a>
        <div class="wt-nav__links">
            <a class="wt-nav__link" href="{{ path('app_home') }}">Accueil</a>
            <a class="wt-nav__link" href="{{ path('app_offers') }}">Offres</a>
            {% if app.user %}
                <a class="wt-nav__link" href="{{ path('app_dashboard') }}">Dashboard</a>
                <a class="wt-nav__link wt-nav__link--pill" href="{{ path('app_logout') }}">Déconnexion</a>
            {% else %}
                <a class="wt-nav__link" href="{{ path('app_login') }}">Connexion</a>
                <a class="wt-nav__link wt-nav__link--pill" href="{{ path('app_registration') }}">S'inscrire</a>
            {% endif %}
        </div>
    </nav>

    {% for label, flashes in app.flashes %}
        {% for msg in flashes %}
            <div class="wt-container" style="padding-top:1rem; position:relative; z-index:2;">
                <div class="wt-flash wt-flash--{{ label }}">{{ msg }}</div>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}

</body>
</html>
