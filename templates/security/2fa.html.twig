{% extends 'base.html.twig' %}

{% block title %}Vérification en deux étapes{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-4">
                <h2 class="mb-4">Vérification en deux étapes</h2>
                <p class="text-muted">Un code vous a été envoyé par mail.</p>

                {% for message in app.flashes('error') %}
                    <div class="alert alert-danger">{{ message }}</div>
                {% endfor %}

                <form method="post" action="{{ path('app_2fa') }}">
                    <div class="mb-3">
                        <label for="code" class="form-label">Code à 6 chiffres</label>
                        <input type="text" id="code" name="code"
                               class="form-control form-control-lg text-center"
                               maxlength="6" autocomplete="off"
                               autofocus required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Valider</button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
