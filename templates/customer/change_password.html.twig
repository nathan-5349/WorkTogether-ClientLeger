{% extends 'base.html.twig' %}
{% block title %}Modifier mon mot de passe{% endblock %}

{% block body %}
    {# change_password #}
    <div class="wt-container">
        <div style="max-width:460px; margin:0 auto; padding:3.5rem 0;">
            <span class="wt-label">{{ 'changePassword.label'|trans }}</span>
            <h1 class="wt-h1" style="font-size:1.8rem; margin-bottom:2rem;">{{ 'changePassword.title'|trans }}</h1>

            <div style="background:var(--glass); backdrop-filter:var(--blur); -webkit-backdrop-filter:var(--blur); border:1px solid var(--border); border-radius:var(--r-lg); padding:2rem;">
                {{ form_start(form) }}
                {{ form_row(form.currentPassword) }}
                <hr style="border:none; border-top:1px solid var(--border); margin:1.25rem 0;">
                {{ form_row(form.password) }}
                <div style="display:flex; gap:.75rem; margin-top:1.5rem;">
                    <button type="submit" class="btn btn-primary">{{ 'changePassword.submit'|trans }}</button>
                    <a href="{{ path('app_customer_profile') }}" class="btn btn-ghost">{{ 'common.cancel'|trans }}</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
