{% extends 'base.html.twig' %}
{% block title %}Mon espace client{% endblock %}

{% block body %}
<style>
    .dash-header {
        padding: 3.5rem 0 2.5rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: 2.5rem;
    }
    .dash-greeting {
        font-family: var(--mono); font-size: .7rem; letter-spacing: .15em;
        text-transform: uppercase; color: var(--cyan); margin-bottom: .5rem;
    }
    .dash-name {
        font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 900;
        letter-spacing: -.04em; line-height: 1.1;
    }

    .dash-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.25rem;
    }

    .dash-tile {
        background: var(--glass);
        backdrop-filter: var(--blur);
        -webkit-backdrop-filter: var(--blur);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        padding: 2rem;
        text-decoration: none; color: var(--text);
        display: flex; flex-direction: column; gap: 1.2rem;
        position: relative; overflow: hidden;
        transition: border-color .25s, transform .25s, box-shadow .25s;
    }
    .dash-tile::after {
        content: '→'; position: absolute; bottom: 1.5rem; right: 1.75rem;
        font-size: 1.1rem; color: var(--muted);
        transition: transform .2s, color .2s;
    }
    .dash-tile:hover {
        border-color: var(--border-h);
        transform: translateY(-4px);
        box-shadow: 0 16px 48px rgba(0,0,0,.4);
    }
    .dash-tile:hover::after { transform: translateX(5px); color: var(--cyan); }

    .dash-tile__icon {
        width: 48px; height: 48px; border-radius: var(--r-md);
        display: flex; align-items: center; justify-content: center; font-size: 1.3rem;
        background: linear-gradient(135deg, rgba(139,92,246,.18), rgba(6,214,247,.1));
        border: 1px solid rgba(139,92,246,.2);
    }
    .dash-tile__label {
        font-family: var(--mono); font-size: .67rem; letter-spacing: .12em;
        text-transform: uppercase; color: var(--muted);
    }
    .dash-tile__title { font-weight: 700; font-size: 1.1rem; letter-spacing: -.02em; }
    .dash-tile__desc  { font-size: .875rem; color: var(--muted); line-height: 1.6; flex: 1; font-weight: 300; }
</style>

<div class="wt-container wt-page">
    <div class="dash-header">
        <p class="dash-greeting">Bienvenue</p>
        <h1 class="dash-name">{{ app.user.firstName }} {{ app.user.name }}</h1>
    </div>

    <div class="dash-grid">
        <a href="{{ path('app_customer_profile') }}" class="dash-tile">
            <div class="dash-tile__icon">👤</div>
            <div>
                <p class="dash-tile__label">Compte</p>
                <p class="dash-tile__title">Mon profil</p>
            </div>
            <p class="dash-tile__desc">Consultez et modifiez vos informations personnelles, adresses et données de facturation.</p>
        </a>

        <a href="{{ path('app_order_reservations') }}" class="dash-tile">
            <div class="dash-tile__icon">🖥</div>
            <div>
                <p class="dash-tile__label">Infrastructure</p>
                <p class="dash-tile__title">Mes réservations</p>
            </div>
            <p class="dash-tile__desc">Gérez vos unités de colocation, consultez les détails de chaque baie et suivez le statut.</p>
        </a>

        <a href="{{ path('app_offers') }}" class="dash-tile">
            <div class="dash-tile__icon">⚡</div>
            <div>
                <p class="dash-tile__label">Catalogue</p>
                <p class="dash-tile__title">Nouvelle réservation</p>
            </div>
            <p class="dash-tile__desc">Découvrez nos offres de colocation et choisissez le forfait adapté à votre infrastructure.</p>
        </a>
    </div>
</div>
{% endblock %}
