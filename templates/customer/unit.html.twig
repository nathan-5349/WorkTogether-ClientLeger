{% extends 'base.html.twig' %}
{% block title %}Unité {{ unit.name }}{% endblock %}

{% block body %}
<style>
    .unit-breadcrumb {
        font-family: var(--mono); font-size: .68rem; letter-spacing: .08em;
        text-transform: uppercase; color: var(--muted);
        padding: 2rem 0 1.25rem; display: flex; align-items: center; gap: .5rem;
    }
    .unit-breadcrumb a { color: var(--muted); text-decoration: none; transition: color .15s; }
    .unit-breadcrumb a:hover { color: var(--cyan); }
    .unit-breadcrumb span { color: var(--muted2); }

    .unit-header {
        display: flex; align-items: center; gap: 1rem; margin-bottom: 2.5rem; flex-wrap: wrap;
    }

    .unit-main {
        display: grid; grid-template-columns: 1fr 340px; gap: 2rem; align-items: start;
    }
    @media (max-width: 800px) { .unit-main { grid-template-columns: 1fr; } }

    .metrics-grid {
        display: grid; grid-template-columns: repeat(3,1fr);
        gap: 1px; background: var(--border);
        border: 1px solid var(--border); border-radius: var(--r-lg); overflow: hidden;
        margin-bottom: 1.5rem;
    }
    .metric {
        background: var(--glass); backdrop-filter: var(--blur); -webkit-backdrop-filter: var(--blur);
        padding: 1.4rem; text-align: center;
    }
    .metric__val {
        font-family: var(--mono); font-size: 1.6rem; font-weight: 700;
        background: linear-gradient(135deg, #c4b5fd, var(--cyan));
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        letter-spacing: -.03em; line-height: 1;
    }
    .metric__unit { font-size: .62em; color: var(--muted); -webkit-text-fill-color: var(--muted); }
    .metric__label { font-family: var(--mono); font-size: .62rem; text-transform: uppercase; letter-spacing: .1em; color: var(--muted); margin-top: .35rem; }

    .info-list {
        background: var(--glass); backdrop-filter: var(--blur); -webkit-backdrop-filter: var(--blur);
        border: 1px solid var(--border); border-radius: var(--r-lg); overflow: hidden;
    }
    .info-row {
        display: flex; justify-content: space-between; align-items: center;
        padding: .85rem 1.4rem; border-bottom: 1px solid var(--border);
    }
    .info-row:last-child { border-bottom: none; }
    .info-row__key { font-family: var(--mono); font-size: .68rem; text-transform: uppercase; letter-spacing: .09em; color: var(--muted); }
    .info-row__val { font-family: var(--mono); font-size: .82rem; font-weight: 500; }

    .edit-panel {
        background: var(--glass); backdrop-filter: var(--blur); -webkit-backdrop-filter: var(--blur);
        border: 1px solid var(--border); border-radius: var(--r-lg); padding: 1.75rem;
    }
    .edit-panel__title {
        font-family: var(--mono); font-size: .68rem; text-transform: uppercase;
        letter-spacing: .12em; color: var(--cyan); margin-bottom: 1.25rem;
    }
</style>

    {# unit #}
    <div class="wt-container wt-page">
        <div class="unit-breadcrumb">
            <a href="{{ path('app_customer_dashboard') }}">{{ 'common.home'|trans }}</a>
            <span>/</span>
            <a href="{{ path('app_order_reservations') }}">{{ 'reservations.pageTitle'|trans }}</a>
            <span>/</span>
            {{ unit.bay.name }}-{{ unit.name }}
        </div>

        <div class="unit-header">
            <h1 class="wt-h1" style="font-size:1.8rem;">{{ unit.bay.name }}-{{ unit.name }}</h1>
            {% set s = unit.status.value %}
            {% if s == 'Libre' %}
                <span class="wt-badge wt-badge--ok">{{ s }}</span>
            {% elseif s == 'Maintenance' %}
                <span class="wt-badge wt-badge--warn">{{ s }}</span>
            {% else %}
                <span class="wt-badge wt-badge--off">{{ s }}</span>
            {% endif %}
        </div>

        <div class="unit-main">
            <div>
                <div class="metrics-grid">
                    <div class="metric">
                        <div class="metric__val">{{ unit.powerConsumption ?? '—' }}<span class="metric__unit"> W</span></div>
                        <div class="metric__label">{{ 'unit.power'|trans }}</div>
                    </div>
                    <div class="metric">
                        <div class="metric__val">{{ unit.temperature is not null ? unit.temperature|number_format(1) : '—' }}<span class="metric__unit"> °C</span></div>
                        <div class="metric__label">{{ 'unit.temperature'|trans }}</div>
                    </div>
                    <div class="metric">
                        <div class="metric__val">{{ unit.networkThroughput is not null ? unit.networkThroughput|number_format(1) : '—' }}<span class="metric__unit"> Gbps</span></div>
                        <div class="metric__label">{{ 'unit.network'|trans }}</div>
                    </div>
                </div>

                <div class="info-list">
                    <div class="info-row">
                        <span class="info-row__key">{{ 'unit.name'|trans }}</span>
                        <span class="info-row__val">{{ unit.name }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-row__key">{{ 'unit.bay'|trans }}</span>
                        <span class="info-row__val">{{ unit.bay.name }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-row__key">{{ 'unit.position'|trans }}</span>
                        <span class="info-row__val">U{{ unit.position }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-row__key">{{ 'unit.type'|trans }}</span>
                        <span class="info-row__val">{{ unit.type ?? 'unit.typeUndefined'|trans }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-row__key">{{ 'unit.location'|trans }}</span>
                        <span class="info-row__val">{{ unit.fullLocation }}</span>
                    </div>
                </div>
            </div>

            <div class="edit-panel">
                <p class="edit-panel__title">{{ 'unit.configure'|trans }}</p>
                {{ form_start(form) }}
                {{ form_row(form.name) }}
                {{ form_row(form.type) }}
                <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; margin-top:.75rem;">
                    {{ 'common.save'|trans }}
                </button>
                {{ form_end(form) }}
            </div>
        </div>

        <div style="margin-top:2rem; display:flex; gap:.75rem;">
            <a href="{{ path('app_order_reservations') }}" class="btn btn-ghost">{{ 'common.back'|trans }}</a>
            <a href="{{ path('app_customer_dashboard') }}" class="btn btn-ghost">{{ 'common.home'|trans }}</a>
        </div>
    </div>
{% endblock %}
